From 8473685c2a2fd1a08fdbb2433abd111c0f6c0fe3 Mon Sep 17 00:00:00 2001
From: Valentin Raevsky <valentin@compulab.co.il>
Date: Mon, 9 Mar 2026 09:36:12 +0200
Subject: [PATCH 2/6] compulab: dts: Update usb ports configuration

Signed-off-by: Valentin Raevsky <valentin@compulab.co.il>
Upstream-Status: Pending
---
 .../nvidia/t23x/nv-public/tegra234-p3768-0000+p3767.dtsi | 9 +++++++--
 hardware/nvidia/t23x/nv-public/tegra234.dtsi             | 2 +-
 2 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/hardware/nvidia/t23x/nv-public/tegra234-p3768-0000+p3767.dtsi b/hardware/nvidia/t23x/nv-public/tegra234-p3768-0000+p3767.dtsi
index 4182135..70431c0 100644
--- a/hardware/nvidia/t23x/nv-public/tegra234-p3768-0000+p3767.dtsi
+++ b/hardware/nvidia/t23x/nv-public/tegra234-p3768-0000+p3767.dtsi
@@ -97,7 +97,7 @@
 
 			ports {
 				/* recovery port */
-				usb2-0 {
+				usb_recovery: usb2-0 {
 					mode = "otg";
 					vbus-supply = <&vdd_5v0_sys>;
 					status = "okay";
@@ -126,7 +126,12 @@
 
 				/* J5 */
 				usb3-1 {
-					nvidia,usb2-companion = <0>;
+					nvidia,usb2-companion = <1>;
+					status = "okay";
+				};
+
+				usb3-2 {
+					nvidia,usb2-companion = <2>;
 					status = "okay";
 				};
 			};
diff --git a/hardware/nvidia/t23x/nv-public/tegra234.dtsi b/hardware/nvidia/t23x/nv-public/tegra234.dtsi
index 99bf4d8..174c03d 100644
--- a/hardware/nvidia/t23x/nv-public/tegra234.dtsi
+++ b/hardware/nvidia/t23x/nv-public/tegra234.dtsi
@@ -3176,7 +3176,7 @@
 
 						usb3-2 {
 							nvidia,function = "xusb";
-							status = "disabled";
+							status = "okay";
 							#phy-cells = <0>;
 						};
 
-- 
