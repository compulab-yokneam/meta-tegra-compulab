From b3f6c2928e347d2f37166d73661c402c0e8d2885 Mon Sep 17 00:00:00 2001
From: Valentin Raevsky <valentin@compulab.co.il>
Date: Mon, 9 Mar 2026 09:41:49 +0200
Subject: [PATCH 4/6] compulab: dts: Change the display@13800000 hotplug
 polarity

Signed-off-by: Valentin Raevsky <valentin@compulab.co.il>
---
 .../nv-platform/tegra234-p3768-0000+p3767-xxxx-nv-common.dtsi   | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/hardware/nvidia/t23x/nv-public/nv-platform/tegra234-p3768-0000+p3767-xxxx-nv-common.dtsi b/hardware/nvidia/t23x/nv-public/nv-platform/tegra234-p3768-0000+p3767-xxxx-nv-common.dtsi
index cb76d57..2ed3600 100644
--- a/hardware/nvidia/t23x/nv-public/nv-platform/tegra234-p3768-0000+p3767-xxxx-nv-common.dtsi
+++ b/hardware/nvidia/t23x/nv-public/nv-platform/tegra234-p3768-0000+p3767-xxxx-nv-common.dtsi
@@ -346,7 +346,7 @@
 
 	display@13800000 {
 		/* os_gpio_hotplug_a is used for hotplug */
-		os_gpio_hotplug_a = <&gpio TEGRA234_MAIN_GPIO(M, 0) GPIO_ACTIVE_HIGH>;
+		os_gpio_hotplug_a = <&gpio TEGRA234_MAIN_GPIO(M, 0) GPIO_ACTIVE_LOW>;
 		status = "okay";
 	};
 
